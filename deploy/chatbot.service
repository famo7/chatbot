[Unit]
Description=Stadfirma Chatbot FastAPI Application
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/chatbot/app
Environment=PATH=/opt/chatbot/app/venv/bin
ExecStart=/opt/chatbot/app/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
